# Contract Deployment Configuration
# Copy this file to .env and fill in your values

# Your wallet private key (NEVER share this or commit it to git!)
# Generate a new wallet at https://metamask.io/ if you don't have one
PRIVATE_KEY="your_ethereum_private_key_here"

# BSC Testnet RPC URL (default provided)
BSC_TESTNET_URL="https://data-seed-preload1-s1.bscnode.com/"

# For mainnet deployment, use:
# BSC_MAINNET_URL="https://bsc-dataseed.binance.org/"
