# Desktop Host Client Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# WALLET CONFIGURATION (Required)
# =============================================================================

# Your host wallet private key
# This wallet will receive CPT tokens for compute jobs
HOST_WALLET_PRIVATE_KEY=your_private_key_here

# =============================================================================
# CONTRACT ADDRESSES (Required)
# =============================================================================

# Marketplace contract address from deployment
MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000

# ComputeCoin (CPT) token contract address from deployment
COMPUTE_COIN_ADDRESS=0x0000000000000000000000000000000000000000

# =============================================================================
# NETWORK CONFIGURATION (Required)
# =============================================================================

# BSC RPC endpoint
# Testnet: https://data-seed-preload1-s1.bscnode.com/
# Mainnet: https://bsc-dataseed.binance.org/
RPC_URL=https://data-seed-preload1-s1.bscnode.com/

# =============================================================================
# HARDWARE CONFIGURATION (Optional)
# =============================================================================

# GPU device ID (0 for first GPU, 1 for second, etc.)
GPU_ID=0

# Maximum price you're willing to accept in CPT per hour
MAX_PRICE_PER_HOUR=10

# Automatically accept jobs without manual approval
# Set to 'true' for fully automated hosting
# Set to 'false' to review each job before accepting
AUTO_ACCEPT_JOBS=false

# =============================================================================
# CPU-ONLY MODE (Optional - for hosts without GPU)
# =============================================================================

# Enable CPU-only mode if you don't have a GPU
CPU_ONLY=false

# Number of CPU cores to offer for compute jobs
CPU_CORES=8

# Amount of RAM in GB to offer for compute jobs
RAM_GB=16

# =============================================================================
# ADVANCED SETTINGS (Optional)
# =============================================================================

# libp2p listen port for P2P communications
# P2P_PORT=4001

# Enable debug logging
# DEBUG=true
